{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\",instance=\"sce-vyos01\"}[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "title": "Memory",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - (node_memory_MemAvailable_bytes{instance=\"sce-vyos01\"} / node_memory_MemTotal_bytes{instance=\"sce-vyos01\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "title": "Disk /",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - (node_filesystem_avail_bytes{instance=\"sce-vyos01\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=\"sce-vyos01\",mountpoint=\"/\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "time() - node_boot_time_seconds{instance=\"sce-vyos01\"}", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "dtdurations", "thresholds": { "steps": [{ "color": "green", "value": null }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "title": "Load Average (5m)",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "node_load5{instance=\"sce-vyos01\"}", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "value" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 4 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "id": 6,
      "title": "Processes",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "node_procs_running{instance=\"sce-vyos01\"}", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 10,
      "title": "Interface Traffic — Physical + Trunk",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{instance=\"sce-vyos01\",device=~\"eth[0-3]\"}[5m]) * 8", "legendFormat": "{{device}} rx", "refId": "A" },
        { "expr": "-rate(node_network_transmit_bytes_total{instance=\"sce-vyos01\",device=~\"eth[0-3]\"}[5m]) * 8", "legendFormat": "{{device}} tx", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 15, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },
    {
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 11,
      "title": "Interface Traffic — VLANs",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{instance=\"sce-vyos01\",device=~\"eth1\\\\..*\"}[5m]) * 8", "legendFormat": "{{device}} rx", "refId": "A" },
        { "expr": "-rate(node_network_transmit_bytes_total{instance=\"sce-vyos01\",device=~\"eth1\\\\..*\"}[5m]) * 8", "legendFormat": "{{device}} tx", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps", "custom": { "fillOpacity": 15, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 20,
      "title": "CPU Usage Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum by (mode) (rate(node_cpu_seconds_total{instance=\"sce-vyos01\",mode!=\"idle\"}[5m]))", "legendFormat": "{{mode}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 50, "lineWidth": 1, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 21,
      "title": "Memory Breakdown",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes{instance=\"sce-vyos01\"} - node_memory_MemAvailable_bytes{instance=\"sce-vyos01\"}", "legendFormat": "Used", "refId": "A" },
        { "expr": "node_memory_Buffers_bytes{instance=\"sce-vyos01\"}", "legendFormat": "Buffers", "refId": "B" },
        { "expr": "node_memory_Cached_bytes{instance=\"sce-vyos01\"}", "legendFormat": "Cached", "refId": "C" },
        { "expr": "node_memory_MemFree_bytes{instance=\"sce-vyos01\"}", "legendFormat": "Free", "refId": "D" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 50, "lineWidth": 1, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 28 },
      "id": 30,
      "title": "Network Errors",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "rate(node_network_receive_errs_total{instance=\"sce-vyos01\"}[5m])", "legendFormat": "{{device}} rx_err", "refId": "A" },
        { "expr": "rate(node_network_transmit_errs_total{instance=\"sce-vyos01\"}[5m])", "legendFormat": "{{device}} tx_err", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "pps", "custom": { "fillOpacity": 10 } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 28 },
      "id": 31,
      "title": "Conntrack",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "node_nf_conntrack_entries{instance=\"sce-vyos01\"}", "legendFormat": "entries", "refId": "A" },
        { "expr": "node_nf_conntrack_entries_limit{instance=\"sce-vyos01\"}", "legendFormat": "limit", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10 } }, "overrides": [] }
    }
  ],
