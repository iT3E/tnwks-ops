{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "id": 1,
      "title": "Cluster Nodes",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "count(kube_node_info)", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "id": 2,
      "title": "Running Pods",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Running\"})", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "id": 3,
      "title": "Firing Alerts",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "count(ALERTS{alertstate=\"firing\",alertname!=\"Watchdog\"}) or vector(0)", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "id": 4,
      "title": "Cluster CPU",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "id": 5,
      "title": "Cluster Memory",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes)", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "id": 6,
      "title": "Uptime",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "min(time() - node_boot_time_seconds)", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "dtdurations", "thresholds": { "steps": [{ "color": "green", "value": null }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "id": 10,
      "title": "CPU Usage by Node",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))", "legendFormat": "{{instance}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 20, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "id": 11,
      "title": "Memory Usage by Node",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "legendFormat": "{{instance}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 20, "lineWidth": 2 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } }
    },
    {
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 12 },
      "id": 20,
      "title": "Windows Host — DESKTOP-HKE05KI",
      "type": "row",
      "collapsed": false
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 13 },
      "id": 21,
      "title": "Win CPU",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - avg(rate(windows_cpu_time_total{mode=\"idle\",instance=\"DESKTOP-HKE05KI\"}[5m]))", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 13 },
      "id": 22,
      "title": "Win Memory",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - (windows_os_physical_memory_free_bytes{instance=\"DESKTOP-HKE05KI\"} / windows_cs_physical_memory_bytes{instance=\"DESKTOP-HKE05KI\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 13 },
      "id": 23,
      "title": "Win Disk C:",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - (windows_logical_disk_free_bytes{volume=\"C:\",instance=\"DESKTOP-HKE05KI\"} / windows_logical_disk_size_bytes{volume=\"C:\",instance=\"DESKTOP-HKE05KI\"})", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 13 },
      "id": 24,
      "title": "Win Network I/O",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        { "expr": "sum(rate(windows_net_bytes_received_total{instance=\"DESKTOP-HKE05KI\"}[5m]))", "legendFormat": "Received", "refId": "A" },
        { "expr": "-sum(rate(windows_net_bytes_sent_total{instance=\"DESKTOP-HKE05KI\"}[5m]))", "legendFormat": "Sent", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "fillOpacity": 20, "lineWidth": 2 } }, "overrides": [] }
    },
    {
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 30,
      "title": "Kubernetes Workloads",
      "type": "row",
      "collapsed": false
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 31,
      "title": "Pod CPU Usage (Top 10)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "topk(10, sum by (namespace, pod) (rate(container_cpu_usage_seconds_total{container!=\"\"}[5m])))", "legendFormat": "{{namespace}}/{{pod}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] } }
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 32,
      "title": "Pod Memory Usage (Top 10)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "topk(10, sum by (namespace, pod) (container_memory_working_set_bytes{container!=\"\"}))", "legendFormat": "{{namespace}}/{{pod}}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 10, "lineWidth": 1 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean"] } }
    },
    {
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 26 },
      "id": 40,
      "title": "Pods Not Ready",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "kube_pod_status_ready{condition=\"false\"} == 1", "format": "table", "instant": true, "refId": "A" }],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["namespace", "pod"] } } }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "showHeader": true }
    },
    {
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 26 },
      "id": 41,
      "title": "Disk Usage (All Volumes)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [{ "expr": "1 - (node_filesystem_avail_bytes{fstype=~\"ext4|xfs\"} / node_filesystem_size_bytes{fstype=~\"ext4|xfs\"})", "legendFormat": "{{instance}} {{mountpoint}}", "refId": "A", "instant": true }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.85 }] } }, "overrides": [] },
      "options": { "orientation": "horizontal", "displayMode": "gradient" }
    }
  ],
